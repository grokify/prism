{
  "$schema": "https://github.com/grokify/prism/schema/prism.schema.json",
  "metadata": {
    "name": "Security Metrics Example",
    "description": "Example PRISM document focused on security metrics",
    "version": "1.0.0",
    "author": "PRISM Team"
  },
  "domains": [
    {
      "name": "security",
      "description": "Application and infrastructure security metrics",
      "weight": 1.0
    }
  ],
  "metrics": [
    {
      "id": "sec-vuln-coverage",
      "name": "Vulnerability Scanning Coverage",
      "description": "Percentage of production assets covered by vulnerability scanning",
      "domain": "security",
      "stage": "runtime",
      "category": "detection",
      "metricType": "coverage",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 60,
      "current": 92,
      "target": 100,
      "thresholds": {
        "green": 95,
        "yellow": 80,
        "red": 60
      },
      "status": "Yellow",
      "slo": {
        "target": ">=95%",
        "window": "30d"
      },
      "maturityMapping": {
        "level1": "<50%",
        "level2": "50-69%",
        "level3": "70-84%",
        "level4": "85-94%",
        "level5": ">=95%"
      },
      "frameworkMappings": [
        {
          "framework": "NIST_CSF",
          "reference": "DE.CM-8"
        }
      ],
      "owner": "Security Engineering",
      "dataSource": "vulnerability-scanner"
    },
    {
      "id": "sec-mttr-critical",
      "name": "MTTR Critical Vulnerabilities",
      "description": "Mean time to remediate critical severity vulnerabilities",
      "domain": "security",
      "stage": "response",
      "category": "response",
      "metricType": "latency",
      "trendDirection": "lower_better",
      "unit": "hours",
      "baseline": 168,
      "current": 24,
      "target": 8,
      "thresholds": {
        "green": 12,
        "yellow": 48,
        "red": 168
      },
      "status": "Yellow",
      "slo": {
        "target": "<=8h",
        "window": "30d"
      },
      "dmaic": {
        "define": "Time from vulnerability discovery to patch deployment",
        "measure": "Track timestamps in ticketing system",
        "analyze": "Identify bottlenecks in remediation workflow",
        "improve": "Automate patch testing and deployment",
        "control": "Monitor SLO compliance weekly"
      },
      "frameworkMappings": [
        {
          "framework": "NIST_CSF",
          "reference": "RS.MI-3"
        }
      ],
      "owner": "Security Operations"
    },
    {
      "id": "sec-sast-coverage",
      "name": "SAST Pipeline Coverage",
      "description": "Percentage of code repos with SAST integrated in CI/CD",
      "domain": "security",
      "stage": "build",
      "category": "prevention",
      "metricType": "coverage",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 40,
      "current": 85,
      "target": 100,
      "thresholds": {
        "green": 90,
        "yellow": 70,
        "red": 50
      },
      "status": "Yellow",
      "slo": {
        "target": ">=90%",
        "window": "30d"
      },
      "owner": "Application Security"
    },
    {
      "id": "sec-threat-model",
      "name": "Threat Modeling Coverage",
      "description": "Percentage of critical services with current threat models",
      "domain": "security",
      "stage": "design",
      "category": "prevention",
      "metricType": "coverage",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 20,
      "current": 65,
      "target": 100,
      "thresholds": {
        "green": 90,
        "yellow": 60,
        "red": 30
      },
      "status": "Yellow",
      "frameworkMappings": [
        {
          "framework": "MITRE_ATTACK",
          "reference": "threat-modeling"
        }
      ],
      "owner": "Security Architecture"
    },
    {
      "id": "sec-pentest-findings",
      "name": "Pentest Finding Closure Rate",
      "description": "Percentage of penetration test findings closed within SLA",
      "domain": "security",
      "stage": "test",
      "category": "quality",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 70,
      "current": 88,
      "target": 95,
      "thresholds": {
        "green": 90,
        "yellow": 75,
        "red": 60
      },
      "status": "Yellow",
      "owner": "Security Engineering"
    }
  ],
  "maturity": {
    "levels": [
      {"level": 1, "name": "Reactive", "description": "Ad-hoc security processes"},
      {"level": 2, "name": "Basic", "description": "Basic security controls in place"},
      {"level": 3, "name": "Defined", "description": "Standardized security practices"},
      {"level": 4, "name": "Managed", "description": "Measured and controlled security"},
      {"level": 5, "name": "Optimizing", "description": "Continuous security improvement"}
    ],
    "cells": [
      {"domain": "security", "stage": "design", "currentLevel": 2, "targetLevel": 4},
      {"domain": "security", "stage": "build", "currentLevel": 3, "targetLevel": 4},
      {"domain": "security", "stage": "test", "currentLevel": 3, "targetLevel": 4},
      {"domain": "security", "stage": "runtime", "currentLevel": 4, "targetLevel": 5},
      {"domain": "security", "stage": "response", "currentLevel": 3, "targetLevel": 4}
    ]
  },
  "okrs": [
    {
      "objectiveName": "Achieve security excellence",
      "keyResultName": "Reach 95% vulnerability coverage",
      "metricIds": ["sec-vuln-coverage"]
    },
    {
      "objectiveName": "Shift security left",
      "keyResultName": "100% SAST integration in pipelines",
      "metricIds": ["sec-sast-coverage", "sec-threat-model"]
    }
  ],
  "initiatives": [
    {
      "id": "init-sast-rollout",
      "name": "SAST Tool Rollout",
      "description": "Deploy SAST scanning to all repositories",
      "status": "in_progress",
      "priority": 1,
      "metricIds": ["sec-sast-coverage"],
      "owner": "Application Security"
    }
  ]
}
